<h1>Витрати</h1>


<table border="1">
  <tr>
    <th>Назва</th>
    <th>Категорія</th>
    <th>Сума</th>
    <th>Статус</th>
    <th>Дії</th>
  </tr>

  <% @expenses.each do |e| %>
    <tr>
      <td><%= e.title %></td>
      <td><%= e.category %></td>
      <td><%= amount_badge(e) %></td>
      <td><%= e.status %></td>

      <td>
        <%= link_to "Показати", e %>
        <%= link_to "Редагувати", edit_expense_path(e) %>

        <%= link_to "Видалити", e,
            data: { turbo_method: :delete, turbo_confirm: "Видалити?" } %>
      </td>
    </tr>
  <% end %>
</table>